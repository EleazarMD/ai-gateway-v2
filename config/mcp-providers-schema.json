{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Providers Configuration Schema",
  "description": "Schema for defining MCP provider configurations in AI Gateway",
  "type": "object",
  "required": ["version", "providers"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Configuration file version"
    },
    "providers": {
      "type": "object",
      "description": "Map of provider configurations",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "object",
          "required": ["baseUrl", "actions", "keyProvider"],
          "properties": {
            "baseUrl": {
              "type": "string",
              "format": "uri",
              "description": "Base URL for the provider's API"
            },
            "description": {
              "type": "string",
              "description": "Human-readable description of the provider"
            },
            "actions": {
              "type": "object",
              "description": "Available actions for this provider",
              "patternProperties": {
                "^[a-z0-9-_]+$": {
                  "type": "object",
                  "required": ["path", "method", "auth"],
                  "properties": {
                    "path": {
                      "type": "string",
                      "description": "API endpoint path"
                    },
                    "method": {
                      "type": "string",
                      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
                      "description": "HTTP method"
                    },
                    "auth": {
                      "type": "string",
                      "enum": ["bearer", "api-key", "api-key-header", "query-token"],
                      "description": "Authentication mechanism"
                    },
                    "description": {
                      "type": "string",
                      "description": "Description of the action"
                    },
                    "rateLimit": {
                      "type": "object",
                      "properties": {
                        "requestsPerMinute": { "type": "integer" },
                        "requestsPerDay": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            },
            "keyProvider": {
              "type": "string",
              "description": "Provider name to fetch API key from AI Inferencing service"
            },
            "timeout": {
              "type": "integer",
              "description": "Request timeout in milliseconds",
              "default": 30000
            }
          }
        }
      }
    }
  }
}
