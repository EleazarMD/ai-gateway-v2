## Config-Based Routing

### How It Works

```javascript
// 1. Configuration file defines providers
// mcp-providers-config.json
{
  "tavily": {
    "baseUrl": "https://api.tavily.com",
    "actions": {
      "search": {
        "path": "/search",
        "method": "POST",
        "auth": "bearer"
      },
      "extract": {
        "path": "/extract",
        "method": "POST",
        "auth": "bearer"
      }
    },
    "keyProvider": "tavily"
  },
  "serper": {
    "baseUrl": "https://google.serper.dev",
    "actions": {
      "search": {
        "path": "/search",
        "method": "POST",
        "auth": "api-key"
      }
    },
    "keyProvider": "serper"
  }
}

// 2. Generic proxy handles all providers
externalApp.all('/api/v1/mcp/:provider/:action', authenticateExternal, async (req, res) => {
  const { provider, action } = req.params;
  
  // Load provider config
  const providerConfig = mcpProvidersConfig[provider];
  const actionConfig = providerConfig.actions[action];
  
  // Fetch API key
  const apiKey = await fetchProviderKey(providerConfig.keyProvider);
  
  // Build request
  const targetUrl = `${providerConfig.baseUrl}${actionConfig.path}`;
  const authHeaders = buildAuthHeaders(actionConfig.auth, apiKey);
  
  // Proxy request
  const response = await axios({
    method: actionConfig.method,
    url: targetUrl,
    data: req.body,
    headers: authHeaders
  });
  
  res.json(response.data);
});
```

### Configuration Schema

```json
{
  "provider_name": {
    "baseUrl": "string",           // Provider's API base URL
    "actions": {
      "action_name": {
        "path": "string",          // Endpoint path
        "method": "GET|POST|PUT",  // HTTP method
        "auth": "bearer|api-key|query-token"  // Auth mechanism
      }
    },
    "keyProvider": "string"        // Which key to fetch from AI Inferencing
  }
}
```

### Auth Mechanisms

```javascript
function buildAuthHeaders(authType, apiKey) {
  switch (authType) {
    case 'bearer':
      return { 'Authorization': `Bearer ${apiKey}` };
      
    case 'api-key':
      return { 'X-API-Key': apiKey };
      
    case 'api-key-header':
      return { 'api-key': apiKey };
      
    case 'query-token':
      // Token goes in query string (handled separately)
      return {};
      
    default:
      return {};
  }
}
```

