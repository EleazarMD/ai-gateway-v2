## Implementation Guide

### Step 1: Add New LLM Capability

**Example: Text Embeddings**

```javascript
// 1. Create generic endpoint
externalApp.post('/api/v1/embeddings/generate', authenticateExternal, async (req, res) => {
  const { model, input } = req.body;
  const provider = detectEmbeddingProvider(model);
  const apiKey = await fetchProviderKey(provider);
  const response = await routeEmbedding(provider, model, input, apiKey);
  res.json(response);
});

// 2. Add provider detection
function detectEmbeddingProvider(model) {
  if (model.includes('embedding-3')) return 'openai';
  if (model.includes('textembedding-gecko')) return 'google';
  if (model.includes('embed-v3')) return 'cohere';
  return null;
}

// 3. Implement provider-specific routing
async function routeEmbedding(provider, model, input, apiKey) {
  switch (provider) {
    case 'openai':
      return await axios.post('https://api.openai.com/v1/embeddings', 
        { model, input },
        { headers: { 'Authorization': `Bearer ${apiKey}` }}
      );
    // ... other providers
  }
}
```

### Step 2: Add New MCP Provider

**Example: Firecrawl Web Scraping**

```json
// 1. Add to mcp-providers-config.json
{
  "firecrawl": {
    "baseUrl": "https://api.firecrawl.dev/v1",
    "actions": {
      "scrape": {
        "path": "/scrape",
        "method": "POST",
        "auth": "bearer"
      },
      "crawl": {
        "path": "/crawl",
        "method": "POST",
        "auth": "bearer"
      }
    },
    "keyProvider": "firecrawl"
  }
}

// 2. Use generic MCP proxy (no code changes needed!)
POST /api/v1/mcp/firecrawl/scrape
{
  "url": "https://example.com"
}
```

