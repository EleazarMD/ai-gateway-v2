// MCP (Model Context Protocol) endpoint for Knowledge Graph integration
internalApp.post('/api/v1/mcp', authenticateInternal, async (req, res) => {
  try {
    const { server, command, args, request_id } = req.body;
    
    console.log(`[INTERNAL-7777] MCP Request: ${command}`, { server, request_id });
    
    // Route to Knowledge Graph service
    if (server === 'knowledge-graph' || !server) {
      const kgUrl = process.env.KG_MCP_URL || 'http://localhost:8766';
      
      try {
        const axios = require('axios');
        const response = await axios.post(`${kgUrl}/mcp`, req.body, {
          headers: {
            'Content-Type': 'application/json'
          },
          timeout: 120000
        });
        
        console.log(`[INTERNAL-7777] MCP Response from KG service:`, response.status);
        res.json(response.data);
        
      } catch (kgError) {
        console.error(`[INTERNAL-7777] KG service error:`, kgError.message);
        
        // Return a mock response for development
        const mockResponse = {
          result: `Mock response for ${command}: ${args?.query || args?.question || 'No query provided'}`,
          confidence: 0.85,
          reasoning: 'Knowledge Graph service unavailable, using mock response',
          sources: [{
            title: 'AI Gateway Mock',
            url: 'http://localhost:7777',
            relevance: 0.9
          }],
          metadata: {
            mock: true,
            timestamp: new Date().toISOString(),
            request_id
          }
        };
        
        res.json(mockResponse);
      }
    } else {
      res.status(400).json({
        error: 'Unknown MCP server',
        message: `Server '${server}' not supported`,
        supported_servers: ['knowledge-graph']
      });
    }
    
  } catch (error) {
    console.error(`[INTERNAL-7777] MCP endpoint error:`, error);
    res.status(500).json({
      error: 'MCP request failed',
      message: error.message
    });
  }
});

