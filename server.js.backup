  console.log(`   Admin: http://localhost:${INTERNAL_PORT}/admin`);
  console.log(`   WebSocket: ws://localhost:${INTERNAL_PORT}/ws`);

  // Fetch API keys from centralized Dashboard FIRST
  console.log('\n🔐 Fetching API keys from centralized Dashboard...');
  await fetchAPIKeysFromDashboard();

  console.log('\n🚀 Initializing Provider Manager...');
  const providerLoadStart = Date.now();

  // Initialize API Key Manager
  try {
    console.log('🔑 Initializing API Key Manager...');
    
    // Initialize with PostgreSQL wrapper and Redis client if available
    const PostgreSQLWrapper = require('./src/storage/postgres-wrapper');
    const postgresWrapper = new PostgreSQLWrapper({
      host: process.env.POSTGRES_HOST || 'postgres-service',
      port: process.env.POSTGRES_PORT || 5432,
      database: process.env.POSTGRES_DB || 'ai_gateway',
      user: process.env.POSTGRES_USER || 'ai_gateway',
      password: process.env.POSTGRES_PASSWORD || 'ai_gateway_pass'
    });
    
    await postgresWrapper.connect();
    
    apiKeyManager = new APIKeyManager({
      postgresWrapper,
      redisClient: null, // Redis integration can be added later
      encryptionKey: process.env.API_KEY_ENCRYPTION_KEY
    });
    
    await apiKeyManager.initialize();
    
    // Initialize API Key routes
    apiKeyRoutes = new APIKeyRoutes(apiKeyManager, console);
    
    // Mount API Key routes now that they're initialized
    if (!apiKeyRoutesSetup) {
      // Add admin authentication middleware first
      internalApp.use('/api/v1/keys', authenticateInternal, (req, res, next) => {
        if (!req.isAdmin) {
          return res.status(403).json({ error: 'Admin access required for API key management' });
        }
        next();
      });
      
      // Then mount the API Key routes
      internalApp.use('/api/v1/keys', apiKeyRoutes.getRouter());
      apiKeyRoutesSetup = true;
      console.log('✅ API Key routes mounted');
    }
    
    console.log('✅ API Key Manager initialized');
  } catch (error) {
    console.error('API Key Manager initialization failed:', error);
    console.warn('Continuing without API key management...');
  }

  // Initialize monitoring storage
  try {
    console.log('📊 Initializing monitoring storage (tracing, costs, alerts)...');
    await traceStorage.initialize();
    await costStorage.initialize();
    await alertStorage.initialize();
    console.log('✅ Monitoring storage initialized');
  } catch (error) {
    console.error('⚠️  Monitoring storage initialization failed:', error.message);
    console.warn('   Traces and costs will be stored in memory only');
  }

  // Initialize Provider Manager with initial configuration
  try {
    console.log('🚀 Initializing Provider Manager...');
    
    // Load initial provider configurations
    const initialProviders = [];
    
    // Add OpenAI provider if API key is available
    if (OPENAI_API_KEY) {
      initialProviders.push({
        id: 'openai',
        name: 'OpenAI',
        type: 'openai',
        endpoint: 'https://api.openai.com/v1',
        apiKey: OPENAI_API_KEY,
        status: 'active',
        capabilities: ['chat', 'reasoning', 'analysis', 'function_calling', 'vision', 'long_context']
      });
    }
    
    // Add OpenAI OSS provider (via Ollama) - only if Ollama is available
    try {
      const ollamaCheck = await axios.get(`${OLLAMA_HOST}/api/tags`, { timeout: 5000 });
      if (ollamaCheck.status === 200) {
        initialProviders.push({
          id: 'openai-oss',
          name: 'OpenAI OSS (via Ollama)',
          type: 'openai-oss',
          endpoint: `${OLLAMA_HOST}/api`,
          status: 'active',
          capabilities: ['chat', 'reasoning', 'analysis', 'function_calling', 'chain_of_thought']
        });
      }
    } catch (error) {
      console.warn(`[Server] Ollama not available at ${OLLAMA_HOST}, skipping OpenAI OSS provider`);
    }
    
    // Add Anthropic provider if API key is available
    if (ANTHROPIC_API_KEY) {
      initialProviders.push({
        id: 'anthropic',
        name: 'Anthropic Claude',
        type: 'anthropic',
        endpoint: 'https://api.anthropic.com/v1',
        apiKey: ANTHROPIC_API_KEY,
        status: 'active',
        capabilities: ['chat', 'reasoning', 'analysis', 'function_calling', 'vision', 'extended_thinking', 'computer_use']
      });
    }
    
    // Add Google provider if API key is available
    if (GOOGLE_API_KEY) {
      initialProviders.push({
        id: 'google',
        name: 'Google Gemini',
        type: 'google',
        endpoint: 'https://generativelanguage.googleapis.com/v1beta',
        apiKey: GOOGLE_API_KEY,
        status: 'active',
        capabilities: ['chat', 'reasoning', 'analysis', 'function_calling', 'vision', 'audio', 'video', 'thinking', 'code_execution']
      });
    }
    
    // Add Perplexity provider if API key is available
    if (PERPLEXITY_API_KEY) {
      initialProviders.push({
        id: 'perplexity',
        name: 'Perplexity AI',
        type: 'perplexity',
        endpoint: 'https://api.perplexity.ai',
        apiKey: PERPLEXITY_API_KEY,
        status: 'active',
        capabilities: ['chat', 'web_search', 'real_time', 'citations', 'reasoning']
      });
    }
    
    // Add OpenAI OSS provider (Ollama) - always available for local inference
    initialProviders.push({
      id: 'openai-oss',
      name: 'Ollama Open Source Models',
      type: 'openai-oss',
      endpoint: `${OLLAMA_HOST}/api`,
      status: 'active',
      capabilities: ['chat', 'reasoning', 'local_inference', 'cost_free', 'privacy_focused']
    });
    
    // Apply initial configuration
    await providerManager.applyConfiguration({ providers: initialProviders });
    
    console.log('✅ Provider Manager initialized with providers:', providerManager.getActiveProviders());
  } catch (error) {
    console.error('Provider Manager initialization failed:', error);
    console.warn('Continuing without provider management...');
  }
  
  // Initialize service mesh protocols
  try {
    serviceMesh = new ServiceMeshIntegration(internalApp, internalServer, authenticateInternal);
    await serviceMesh.initialize();
    console.log('✅ Service mesh protocols initialized');
  } catch (error) {
    console.error('Service mesh initialization failed:', error);
    console.warn('Continuing without service mesh protocols...');
  }

  // Skip Enhanced Configuration Service - use in-memory configuration only
  console.log('⚠️  Enhanced Configuration Service DISABLED - using in-memory provider configuration');
  console.log('   Providers will maintain current active state without database override');

  // Initialize AHIS Integration Service
  try {
    const ahisIntegration = new AHISIntegrationService({
      gatewayPort: INTERNAL_PORT,
      syncInterval: parseInt(process.env.AHIS_SYNC_INTERVAL) || 120000,
      apiKey: API_KEY,
      enabled: process.env.ENABLE_AHIS_INTEGRATION !== 'false'
    });

    await ahisIntegration.start();
    console.log(`   AHIS Integration: ${ahisIntegration.ahisUrl}`);
    console.log(`   Platform Sync: ${ahisIntegration.syncInterval}ms interval`);

    // Listen to AHIS integration events
    ahisIntegration.on('platform_sync_complete', (event) => {
      console.log(`[AHIS] Platform sync complete: ${event.providersCount} providers, ${event.agentsCount} agents`);
      
      // Merge AHIS providers with dashboard configuration
      if (dashboardConfig) {
        mergeAHISProvidersWithDashboard();
      }
      
      // Broadcast platform update via service mesh
      if (serviceMesh) {
        serviceMesh.broadcastEvent('platform_providers_updated', {
          providersCount: event.providersCount,
          agentsCount: event.agentsCount,
          timestamp: event.timestamp
        });
      }
    });

    ahisIntegration.on('providers_updated', (event) => {
      console.log(`[AHIS] Providers updated: ${event.count} platform providers discovered`);
    });

    ahisIntegration.on('agents_updated', (event) => {
      console.log(`[AHIS] Agents updated: ${event.count} platform agents discovered`);
    });

    ahisIntegration.on('sync_error', (event) => {
      console.error(`[AHIS] Platform sync error: ${event.error}`);
    });

  } catch (error) {
    console.error('AHIS Integration Service initialization failed:', error);
    console.warn('Continuing without AHIS platform discovery...');
  }
});

// Start external server (AI inference)
const externalServer = externalApp.listen(EXTERNAL_PORT, () => {
  console.log(`🤖 AI Gateway v2.0 EXTERNAL (AI Inference) running on port ${EXTERNAL_PORT}`);
  console.log(`   Health: http://localhost:${EXTERNAL_PORT}/health`);
  console.log(`   Chat: http://localhost:${EXTERNAL_PORT}/api/v1/chat/completions`);
  console.log(`   Models: http://localhost:${EXTERNAL_PORT}/api/v1/models`);
  console.log(`   Perplexity: http://localhost:${EXTERNAL_PORT}/api/v1/perplexity/search`);
  console.log(`   Proxying to: ${OLLAMA_HOST}`);
});

console.log('\n✅ AI Gateway v2.0 Dual-Port Architecture Ready');
console.log(`   TripCraft → External Port ${EXTERNAL_PORT}`);
console.log(`   Ecosystem Services → Internal Port ${INTERNAL_PORT}`);

// Graceful shutdown for both servers
const shutdown = async () => {
  console.log('\n🛑 Shutting down AI Gateway v2.0 Dual-Port...');
  
  // Shutdown service mesh protocols first
  if (serviceMesh) {
    await serviceMesh.shutdown();
  }
  
  internalServer.close(() => {
    console.log('Internal server closed');
  });
  externalServer.close(() => {
    console.log('External server closed');
  });
  process.exit(0);
};

process.on('SIGINT', shutdown);
process.on('SIGTERM', shutdown);
