});

// Early model normalization so routing always sees Claude models for B1
// Can be bypassed with X-Use-Native-Model: true header to access real OpenAI models
externalApp.use('/api/v1/chat/completions', (req, res, next) => {
  try {
    // Check for bypass header
    const useNativeModel = req.headers['x-use-native-model'] === 'true' || 
                           req.headers['x-skip-aliasing'] === 'true';
    
    if (useNativeModel) {
      console.log(`[Model Normalizer] Skipping aliasing (X-Use-Native-Model: true) - using model as-is: ${req.body?.model}`);
      return next();
    }

    const original = req.body?.model;
    if (typeof original === 'string') {
      const ml = original.toLowerCase();
      let normalized = original;
      if (ml === 'gpt-4o' || ml.startsWith('gpt-4o-')) {
        normalized = 'claude-4-sonnet';
      } else if (ml === 'gpt-4o-mini' || ml.startsWith('gpt-4o-mini-')) {
        normalized = 'claude-3-5-haiku';
      } else if (ml === 'claude-sonnet-4-0') {
        normalized = 'claude-4-sonnet';
      }
      if (normalized !== original) {
        console.log(`[Model Normalizer] ${original} → ${normalized}`);
        req.body.model = normalized;
      }
    }
  } catch (e) {
    console.warn('[Model Normalizer] Skipped normalization:', e.message);
  }
  return next();
});

// Authentication for chat completions
externalApp.use('/api/v1/chat/completions', authenticateExternal);

// Chat completions endpoint with transparent error reporting
externalApp.post('/api/v1/chat/completions', authenticateExternal, async (req, res) => {
  // Start request tracing
  const { traceId, spanId } = tracingService.startTrace(req.body, {
    clientId: req.headers['x-client-id'] || 'unknown',
    clientIp: req.ip || req.connection.remoteAddress,
    userAgent: req.headers['user-agent'],
    routingStrategy: req.headers['x-routing-strategy'] || 'hybrid',
  });
  
  const requestStartTime = Date.now();
  
  try {
    // Extract service context for multi-tenant key management
    const serviceId = req.headers['x-service-id'] || req.body._context?.serviceId || 'default-service';
    const projectId = req.headers['x-project-id'] || req.body._context?.projectId || null;
    let model = req.body.model;
    
    // Model aliasing for Goose CLI compatibility
    // Goose's OpenAI provider validates model names client-side, so we accept Goose-friendly names
    // and route to the correct Claude models internally
    const MODEL_ALIASES = {
      // Goose Anthropic-friendly names -> internal canonical
      'claude-sonnet-4-0': 'claude-4-sonnet',
      'claude-opus-4-0': 'claude-4-opus',
      'claude-opus-4-1-0': 'claude-4-1-opus',
      // OpenAI names -> route to Anthropic (Option B1)
      'gpt-4o': 'claude-4-sonnet',
      'gpt-4o-mini': 'claude-3-5-haiku'
    };
    
    // Also support versioned variants like gpt-4o-2024-08-06
    if (typeof model === 'string') {
      const ml = model.toLowerCase();
      if (ml.startsWith('gpt-4o-')) {
        console.log(`[Model Aliasing] ${model} → claude-4-sonnet`);
        model = 'claude-4-sonnet';
        req.body.model = model;
      } else if (ml.startsWith('gpt-4o-mini-')) {
        console.log(`[Model Aliasing] ${model} → claude-3-5-haiku`);
        model = 'claude-3-5-haiku';
        req.body.model = model;
      }
    }
    
    if (MODEL_ALIASES[model]) {
      console.log(`[Model Aliasing] ${model} → ${MODEL_ALIASES[model]}`);
      model = MODEL_ALIASES[model];
      req.body.model = model; // Update request body for downstream processing
    }
    
    console.log(`[AI Gateway] Request from service: ${serviceId}${projectId ? `, project: ${projectId}` : ''} [Trace: ${traceId}]`);
    
    // Fast-path: If model is a Claude model, directly execute with Anthropic provider
    if (typeof model === 'string' && model.toLowerCase().startsWith('claude-')) {
      try {
        const provider = providerManager.getProviderForModel(model);
        if (provider && typeof provider.processChatCompletion === 'function') {
          console.log(`[AI Gateway] Direct execution via Anthropic provider for model: ${model}`);
          const directResponse = await provider.processChatCompletion({
            ...req.body,
            model,
            _inferencingKey: req.body._inferencingKey
          });
          return res.json(directResponse);
        }
      } catch (directErr) {
        console.warn('[AI Gateway] Direct Anthropic execution failed, falling back to routing:', directErr.message);
      }
    }
    
    // If multi-tenant is enabled, fetch API key from AI Inferencing Service
    if (ENABLE_AI_INFERENCING && serviceId !== 'default-service') {
      const provider = determineProviderFromModel(model);
      
      if (provider) {
        try {
          console.log(`[AI Inferencing] Fetching ${provider} key for service: ${serviceId}`);
          const apiKey = await inferencingClient.getKey(serviceId, provider);
          
          if (apiKey) {
            console.log(`[AI Inferencing] ✅ Key retrieved for ${serviceId}/${provider} (cached: ${inferencingClient.cache.has(`${serviceId}:${provider}`)})`);
            
            // Override the provider's API key with the fetched key
            // This will be used by the provider manager
            req.body._inferencingKey = {
              provider,
              apiKey,
              serviceId
            };
          } else {
            console.warn(`[AI Inferencing] ⚠️  No key found for ${serviceId}/${provider}, falling back to .env`);
          }
        } catch (error) {
          console.error(`[AI Inferencing] ❌ Error fetching key for ${serviceId}/${provider}:`, error.message);
          // Continue with fallback to .env keys
        }
      }
    }
    
    // Check if model aliasing should be bypassed
    const skipAliasing = req.headers['x-use-native-model'] === 'true' || 
                         req.headers['x-skip-aliasing'] === 'true';

    const requestOptions = {
      strategy: req.headers['x-routing-strategy'] || 'hybrid',
      enableFallback: false, // Disable automatic fallbacks
      skipAliasing: skipAliasing // Pass bypass flag to routing layers
    };

    console.log(`[AI Gateway] Processing chat completion with strategy: ${requestOptions.strategy} [Trace: ${traceId}]`);
    
    // Get provider connectivity status first
    const connectivityStatus = await providerManager.getProviderConnectivityStatus();
    
    // Try intelligent routing
    const routingStartTime = Date.now();
    const response = await providerManager.routeRequest(req.body, requestOptions);
    const routingDuration = Date.now() - routingStartTime;
    
    // Update trace with routing information
    if (response && response.routing) {
      tracingService.updateRouting(traceId, {
        provider: response.routing.provider,
        strategy: requestOptions.strategy,
        routingTime: routingDuration,
      });
    }

    // Calculate cost and record
    if (response && response.usage) {
      const cost = await costService.calculateCost(
        response.routing?.provider || 'unknown',
        req.body.model,
        response.usage
      );
      
      await costService.recordCost(traceId, response.routing?.provider || 'unknown', req.body.model, response.usage, {
        clientId: req.headers['x-client-id'] || 'unknown',
      });
      
      // Complete trace with success
      tracingService.completeTrace(traceId, response, {
        tokens: response.usage,
        cost,
        latency: {
          routing: routingDuration,
          provider: Date.now() - requestStartTime - routingDuration,
          total: Date.now() - requestStartTime,
        },
      });
    }
    
    // Add gateway metadata with connectivity info
    if (response && typeof response === 'object') {
      response._gateway = {
        version: '2.4.0',
        timestamp: new Date().toISOString(),
        traceId: traceId,
        routing: response.routing || null,
        connectivity: {
          selectedProvider: response.routing?.provider,
          providerStatus: connectivityStatus[response.routing?.provider] || 'unknown',
          allProviders: connectivityStatus
        }
      };
    }

    res.json(response);
  } catch (error) {
    console.error('[AI Gateway] Chat completion request failed:', error?.message || error);
    if (error && error.stack) {
      console.error('[AI Gateway] Chat completion stack:', error.stack);
    }
    
    // Record error in trace
    tracingService.recordError(traceId, error, 500);
    
    // Get detailed connectivity status for error response (safe defaults)
    let connectivityStatus = {};
    try {
      connectivityStatus = (await providerManager.getProviderConnectivityStatus()) || {};
    } catch (e) {
      console.warn('[AI Gateway] Failed to fetch connectivity status:', e.message);
    }
    const entries = Array.isArray(Object.entries(connectivityStatus)) ? Object.entries(connectivityStatus) : [];
    const availableProviders = entries
      .filter(([, status]) => status && status.connected)
      .map(([provider]) => provider);

    const suggestion = Array.isArray(availableProviders) && availableProviders.length > 0
      ? `Try using a model from available providers: ${availableProviders.join(', ')}`
      : 'No providers are currently available. Check your API keys and network connectivity.';

    res.status(500).json({
      error: {
        message: error?.message || 'Unknown error',
        type: 'connectivity_error',
        code: 'PROVIDER_UNAVAILABLE',
        details: {
          requestedModel: req?.body?.model,
          connectivity: connectivityStatus,
          availableProviders: availableProviders || [],
          suggestion
        }
      },
      _gateway: {
        version: '2.4.0',
        timestamp: new Date().toISOString(),
        error: true,
        connectivity: connectivityStatus
      }
    });
  }
});

// ============================================================================
// ANTHROPIC NATIVE API ENDPOINT
// ============================================================================
// Support Anthropic's native /v1/messages endpoint for clients like Goose CLI
externalApp.post('/v1/messages', authenticateExternal, async (req, res) => {
  const { traceId, spanId } = tracingService.startTrace(req.body, {
    clientId: req.headers['x-client-id'] || 'unknown',
    clientIp: req.ip || req.connection.remoteAddress,
    userAgent: req.headers['user-agent'],
    apiFormat: 'anthropic-native',
  });
  
  const requestStartTime = Date.now();
  
  try {
    const serviceId = req.headers['x-service-id'] || 'default-service';
    const projectId = req.headers['x-project-id'] || null;
    
    // Anthropic native request has 'model' field directly
    const model = req.body.model;
    
    console.log(`[Anthropic Native] Request from service: ${serviceId}, model: ${model} [Trace: ${traceId}]`);
    console.log(`[Anthropic Native] Request body keys:`, Object.keys(req.body));
    console.log(`[Anthropic Native] Full model value:`, JSON.stringify({model: req.body.model}));
    
    // Fetch API key from AI Inferencing if multi-tenant enabled
    if (ENABLE_AI_INFERENCING && serviceId !== 'default-service') {
      try {
        console.log(`[AI Inferencing] Fetching anthropic key for service: ${serviceId}`);
        const apiKey = await inferencingClient.getKey(serviceId, 'anthropic');
        
        if (apiKey) {
          console.log(`[AI Inferencing] ✅ Key retrieved for ${serviceId}/anthropic`);
          req.body._inferencingKey = {
            provider: 'anthropic',
            apiKey,
            serviceId
          };
        }
      } catch (error) {
        console.error(`[AI Inferencing] ❌ Error fetching key:`, error.message);
      }
    }
    
    // Convert Anthropic request to internal format for provider manager
    const internalRequest = {
      model: model,
      messages: req.body.messages,
      max_tokens: req.body.max_tokens,
      temperature: req.body.temperature,
      system: req.body.system,
      tools: req.body.tools,
      stream: req.body.stream,
      _inferencingKey: req.body._inferencingKey,
      _anthropicNative: true // Flag for provider to return native format
    };
    
    console.log(`[Anthropic Native] Sending to provider manager:`, JSON.stringify({
      model: internalRequest.model,
      hasMessages: !!internalRequest.messages,
      max_tokens: internalRequest.max_tokens
    }));
    
    console.log(`[Routing Precheck] final model before routing: ${internalRequest.model}`);
    const response = await providerManager.routeRequest(internalRequest, {
      strategy: 'hybrid',
      traceId,
      spanId
    });
    
    // If the provider returned Anthropic native format, pass it through
    // Otherwise, convert OpenAI format to Anthropic format
    if (response._anthropicNative || response.type === 'message') {
      res.json(response);
    } else {
      // Convert OpenAI format to Anthropic format
      const anthropicResponse = {
        id: response.id || `msg_${Date.now()}`,
        type: 'message',
        role: 'assistant',
        content: response.choices?.[0]?.message?.content ? 
          [{ type: 'text', text: response.choices[0].message.content }] : [],
        model: response.model,
        stop_reason: response.choices?.[0]?.finish_reason === 'stop' ? 'end_turn' : 'max_tokens',
        usage: {
          input_tokens: response.usage?.prompt_tokens || 0,
          output_tokens: response.usage?.completion_tokens || 0
        }
      };
      res.json(anthropicResponse);
    }
    
    // Record successful trace
    const requestDuration = Date.now() - requestStartTime;
    tracingService.completeTrace(traceId, response, requestDuration);
    
    // Track costs
    if (response.usage) {
      await costTrackingService.recordRequest({
        traceId,
        serviceId,
        model: response.model,
        provider: 'anthropic',
        usage: response.usage,
        cost: response.cost || 0,
        duration: requestDuration
      });
    }
    
  } catch (error) {
    console.error('[Anthropic Native] Request failed:', error);
    tracingService.recordError(traceId, error, 500);
    
    // Return Anthropic-format error
    res.status(500).json({
      type: 'error',
      error: {
        type: 'api_error',
        message: error.message
      }
    });
  }
});

