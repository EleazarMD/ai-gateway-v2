// Global service mesh integration instance
let serviceMesh = null;

// Global dashboard configuration service instance
let dashboardConfig = null;

// Global AHIS integration service instance
let ahisIntegration = null;

/**
 * Merge AHIS-discovered providers with dashboard configuration
 */
function mergeAHISProvidersWithDashboard() {
  if (!ahisIntegration || !dashboardConfig) {
    return;
  }

  try {
    console.log('[CONFIG] Merging AHIS providers with dashboard configuration...');
    
    const ahisProviders = ahisIntegration.getPlatformProviders();
    const currentConfig = dashboardConfig.getCurrentConfiguration();
    
    if (!currentConfig) {
      console.warn('[CONFIG] No dashboard configuration available for merging');
      return;
    }

    // Create a map of existing dashboard providers
    const dashboardProviderMap = new Map();
    (currentConfig.providers || []).forEach(provider => {
      dashboardProviderMap.set(provider.id, provider);
    });

    // Merge AHIS providers with dashboard providers
    const mergedProviders = [...currentConfig.providers];
    let addedCount = 0;
    let updatedCount = 0;

    ahisProviders.forEach(ahisProvider => {
      const existingProvider = dashboardProviderMap.get(ahisProvider.id);
      
      if (existingProvider) {
        // Update existing provider with AHIS information
        existingProvider.endpoint = ahisProvider.endpoint;
        existingProvider.lastUpdated = ahisProvider.lastUpdated;
        existingProvider.source = 'ahis_merged';
        existingProvider.serviceId = ahisProvider.serviceId;
        existingProvider.ports = ahisProvider.ports;
        
        // Merge capabilities
        const combinedCapabilities = [...new Set([
          ...(existingProvider.capabilities || []),
          ...(ahisProvider.capabilities || [])
        ])];
        existingProvider.capabilities = combinedCapabilities;
        
        // Merge models
        const combinedModels = [...new Set([
          ...(existingProvider.models || []),
          ...(ahisProvider.models || [])
        ])];
        existingProvider.models = combinedModels;
        
        updatedCount++;
      } else {
        // Add new AHIS provider
        mergedProviders.push({
          ...ahisProvider,
          source: 'ahis'
        });
        addedCount++;
      }
    });

    // Update the dashboard configuration with merged providers
    const mergedConfig = {
      ...currentConfig,
      providers: mergedProviders,
      lastSync: new Date().toISOString(),
      ahisIntegration: {
        enabled: true,
        lastMerge: new Date().toISOString(),
        addedProviders: addedCount,
        updatedProviders: updatedCount
      }
    };

    // Apply the merged configuration
    dashboardConfig.applyConfiguration(mergedConfig);
    
    console.log(`[CONFIG] AHIS merge complete: ${addedCount} added, ${updatedCount} updated`);
    
  } catch (error) {
    console.error('[CONFIG] Error merging AHIS providers with dashboard:', error.message);
  }
}

/**
 * Handle Perplexity search with dynamic provider selection
 */
async function handleDynamicPerplexitySearch(req, res, configService) {
  const { query, model = 'sonar', stream = false } = req.body;
  
  // Select appropriate provider for Perplexity search
  const provider = configService.selectProvider({
    capability: 'web_search',
    model: model,
    resourceId: 'perplexity_search'
  });

  if (!provider) {
    throw new Error('No suitable provider found for Perplexity search');
  }

  console.log(`[EXTERNAL-8777] Using provider: ${provider.name} (${provider.type}) for Perplexity search`);

  // Build request based on provider configuration
  const perplexityRequest = {
    model: model,
    messages: [
      {
        role: 'system',
        content: 'You are a helpful search assistant. Provide comprehensive answers with citations.'
      },
      {
        role: 'user',
        content: query
      }
    ],
    max_tokens: req.body.maxTokens || provider.settings.maxTokens || 4000,
    temperature: req.body.temperature || provider.settings.temperature || 0.2,
    return_citations: true,
    return_related_questions: true,
    search_recency_filter: 'month',
    stream: stream
  };

  // Apply provider-specific settings
  if (provider.settings.topP !== undefined) {
    perplexityRequest.top_p = provider.settings.topP;
  }

  // Determine API endpoint and headers
  const apiUrl = provider.endpoint || 'https://api.perplexity.ai/chat/completions';
  const headers = {
    'Authorization': `Bearer ${provider.apiKey || PERPLEXITY_API_KEY}`,
    'Content-Type': 'application/json',
    ...provider.settings.customHeaders
  };

  const timeout = provider.settings.timeout || 120000;

  try {
    if (stream) {
      // Handle streaming response
      res.writeHead(200, {
        'Content-Type': 'text/event-stream',
        'Cache-Control': 'no-cache',
        'Connection': 'keep-alive',
        'Access-Control-Allow-Origin': '*',
        'Access-Control-Allow-Headers': 'Cache-Control'
      });

      const perplexityResponse = await axios.post(apiUrl, perplexityRequest, {
        headers: headers,
        timeout: timeout,
        responseType: 'stream'
      });

      perplexityResponse.data.on('data', (chunk) => {
        res.write(chunk);
      });

      perplexityResponse.data.on('end', () => {
        res.end();
      });

      perplexityResponse.data.on('error', (error) => {
        console.error(`[EXTERNAL-8777] Provider ${provider.name} streaming error:`, error);
        res.write(`data: {"error": "Stream error: ${error.message}"}\n\n`);
        res.end();
      });

    } else {
      // Handle non-streaming response
      const perplexityResponse = await axios.post(apiUrl, perplexityRequest, {
        headers: headers,
        timeout: timeout
      });

      // Add provider metadata to response
      const enhancedResponse = {
        ...perplexityResponse.data,
        _provider: {
          id: provider.id,
          name: provider.name,
          type: provider.type
        }
      };

      res.json(enhancedResponse);
    }

    console.log(`[EXTERNAL-8777] Provider ${provider.name} completed Perplexity search successfully`);

  } catch (error) {
    console.error(`[EXTERNAL-8777] Provider ${provider.name} Perplexity search error:`, error.message);
    
    // Try fallback providers
    const fallbackProviders = configService.getFallbackChain(provider.id);
    
    if (fallbackProviders.length > 0) {
      console.log(`[EXTERNAL-8777] Attempting fallback with ${fallbackProviders.length} providers`);
      
      for (const fallbackProvider of fallbackProviders) {
        if (fallbackProvider.capabilities.includes('web_search')) {
          try {
            console.log(`[EXTERNAL-8777] Trying fallback provider: ${fallbackProvider.name}`);
            
            // Recursive call with fallback provider (simplified)
            const fallbackRequest = { ...req };
            fallbackRequest.body._selectedProvider = fallbackProvider.id;
            
            return await handleDynamicPerplexitySearch(fallbackRequest, res, configService);
            
          } catch (fallbackError) {
            console.error(`[EXTERNAL-8777] Fallback provider ${fallbackProvider.name} also failed:`, fallbackError.message);
            continue;
          }
        }
      }
    }
    
    // All providers failed
throw error;
}

}

// Start internal server (service mesh) with WebSocket support
const internalServer = http.createServer(internalApp);
const wss = new WebSocket.Server({ 
  noServer: true,
  verifyClient: (info) => {
    try {
      // Verify API key from query parameter
      const url = new URL(info.req.url, `http://${info.req.headers.host}`);
      const apiKey = url.searchParams.get('apiKey');
      console.log(`[WebSocket] Auth attempt - provided: ${apiKey ? 'present' : 'missing'}, expected: ${API_KEY ? 'present' : 'missing'}`);
      return apiKey === API_KEY;
    } catch (error) {
      console.error('[WebSocket] Auth error:', error.message);
      return false;
    }
  }
});

// Handle WebSocket upgrade manually
internalServer.on('upgrade', (request, socket, head) => {
  const pathname = new URL(request.url, `http://${request.headers.host}`).pathname;
  
  if (pathname === '/ws') {
    wss.handleUpgrade(request, socket, head, (ws) => {
      wss.emit('connection', ws, request);
    });
  } else {
    socket.destroy();
  }
});

// WebSocket connection handling
wss.on('connection', (ws, req) => {
  console.log('Dashboard WebSocket connected');
  
  // Store subscriptions for this connection
  ws.subscriptions = new Set();
  
  // Send initial connection confirmation
  ws.send(JSON.stringify({
    type: 'connection_established',
    data: { timestamp: new Date().toISOString() }
  }));

  // Handle subscription requests
  ws.on('message', (message) => {
    try {
      const data = JSON.parse(message);
      if (data.type === 'subscribe') {
        const channel = data.channel;
        console.log('Dashboard subscribed to:', channel);
        
        // Add to subscriptions
        ws.subscriptions.add(channel);
        
        // Acknowledge subscription
        ws.send(JSON.stringify({
          type: 'subscription_confirmed',
          data: { channel: channel }
        }));
        
        // Start sending data for this channel
        if (channel === 'health') {
          // Send immediate health data
          sendHealthData(ws);
          // Set up periodic health updates
          if (!ws.healthInterval) {
            ws.healthInterval = setInterval(() => {
              if (ws.subscriptions.has('health') && ws.readyState === 1) {
                sendHealthData(ws);
              }
            }, 10000);
          }
        } else if (channel === 'metrics') {
          // Send immediate metrics data
          sendMetricsData(ws);
          // Set up periodic metrics updates
          if (!ws.metricsInterval) {
            ws.metricsInterval = setInterval(() => {
              if (ws.subscriptions.has('metrics') && ws.readyState === 1) {
                sendMetricsData(ws);
              }
            }, 30000);
          }
        }
      }
    } catch (error) {
      console.error('WebSocket message error:', error);
    }
  });

  ws.on('close', () => {
    console.log('Dashboard WebSocket disconnected');
    // Clean up intervals
    if (ws.healthInterval) clearInterval(ws.healthInterval);
    if (ws.metricsInterval) clearInterval(ws.metricsInterval);
  });

  ws.on('error', (error) => {
    console.error('WebSocket error:', error);
  });
});

// Helper functions for sending data
function sendHealthData(ws) {
  if (ws.readyState !== 1) return;
  
  const healthData = {
    status: 'healthy',
    timestamp: new Date().toISOString(),
    uptime: process.uptime(),
    memory: process.memoryUsage(),
    port: INTERNAL_PORT
  };
  
  ws.send(JSON.stringify({
    type: 'health',
    data: healthData,
    timestamp: new Date().toISOString()
  }));
}

function sendMetricsData(ws) {
  if (ws.readyState !== 1) return;
  
  const metricsData = {
    timestamp: new Date().toISOString(),
    requests: {
      total: 0, // Would track actual requests
      internal: 0,
      external: 0
    },
    providers: {
      ollama: 'connected',
      perplexity: 'configured'
    },
    performance: {
      cpu: process.cpuUsage(),
      memory: process.memoryUsage()
    }
  };
  
  ws.send(JSON.stringify({
    type: 'metrics',
    data: metricsData,
    timestamp: new Date().toISOString()
  }));
}

