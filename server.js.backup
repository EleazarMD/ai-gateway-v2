// Fallback chain registration endpoint
externalApp.post('/api/v1/config/fallback/chains', authenticateExternal, async (req, res) => {
  try {
    const { name, providers, description } = req.body;
    
    if (!name || !providers || !Array.isArray(providers)) {
      return res.status(400).json({
        success: false,
        error: 'Invalid chain configuration. Name and providers array required.',
        timestamp: new Date().toISOString()
      });
    }
    
    // Register the custom fallback chain
    const fallbackManager = providerManager.fallbackManager;
    if (fallbackManager && fallbackManager.registerFallbackChain) {
      fallbackManager.registerFallbackChain(name, providers, description);
    }
    
    res.json({
      success: true,
      message: `Fallback chain '${name}' registered successfully`,
      chain: { name, providers, description },
      timestamp: new Date().toISOString()
    });
  } catch (error) {
    res.status(500).json({
      success: false,
      error: error.message,
      timestamp: new Date().toISOString()
    });
  }
});

