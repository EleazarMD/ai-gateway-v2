        totalProviders: Object.keys(connectivityStatus).length,
        connectedProviders: Object.values(connectivityStatus).filter(p => p.connected).length,
        healthyProviders: Object.values(connectivityStatus).filter(p => p.status === 'healthy').length
      }
    });
  } catch (error) {
    console.error('[INTERNAL-7777] Provider status error:', error);
    res.status(500).json({
      success: false,
      error: 'Provider status check failed',
      message: error.message
    });
