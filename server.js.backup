        method: 'POST',
        authentication: 'X-API-Key',
        description: 'OpenAI-compatible chat completions with intelligent provider routing',
        parameters: {
          required: ['messages', 'model'],
          optional: ['temperature', 'max_tokens', 'stream', 'top_p', 'frequency_penalty', 'presence_penalty', 'stop']
        },
        body_example: {
          model: 'gpt-4',
          messages: [{ role: 'user', content: 'Hello' }],
          temperature: 0.7
        },
        features: ['streaming', 'function-calling', 'vision', 'provider-fallback']
      },
      {
        path: '/api/v1/models',
        method: 'GET',
        authentication: 'X-API-Key',
        description: 'List all available models across all providers',
        response: {
          object: 'list',
          data: [{ id: 'model-name', provider: 'provider', capabilities: [] }]
        }
      },
      {
        path: '/api/v1/tts',
        method: 'POST',
        authentication: 'X-API-Key',
        description: 'Text-to-Speech with parameter-based routing (single-speaker or multi-speaker)',
        parameters: {
          single_speaker: {
            required: ['text', 'voice', 'model'],
            optional: ['speed', 'pitch', 'volumeGainDb', 'sampleRateHertz']
          },
          multi_speaker: {
            required: ['mode', 'script', 'speakerVoices', 'model'],
            optional: []
          }
        },
        body_examples: {
          single_speaker: {
            text: 'Hello world',
            voice: 'Puck',
            model: 'gemini-2.5-flash-preview-tts',
            speed: 1.0,
            pitch: 0
          },
          multi_speaker: {
            mode: 'multi-speaker',
            script: 'Host: Welcome!\\nGuest: Thanks!',
            speakerVoices: [
              { speaker: 'Host', voiceName: 'Puck' },
              { speaker: 'Guest', voiceName: 'Charon' }
            ],
            model: 'gemini-2.5-flash-preview-tts'
          }
        },
        supported_voices: ['Puck', 'Charon', 'Kore', 'Fenrir', 'Aoede'],
        response_type: 'audio/wav'
      },
      {
        path: '/api/v1/perplexity/search',
        method: 'POST',
        authentication: 'X-API-Key',
        description: 'RAG-enhanced search using Perplexity AI',
        parameters: {
          required: ['query'],
          optional: ['model', 'max_tokens', 'temperature']
        },
        body_example: {
          query: 'Latest AI developments',
          model: 'sonar-pro',
          max_tokens: 1000
        }
      },
      {
        path: '/api/v1/config/routing',
        method: 'PUT',
        authentication: 'X-API-Key',
        description: 'Update routing configuration',
        parameters: {
          required: ['strategy'],
          optional: ['fallbackChain', 'latencyThreshold']
        }
      },
      {
        path: '/api/v1/analytics/routing',
        method: 'GET',
        authentication: 'X-API-Key',
        description: 'Get routing analytics and provider usage statistics',
        query_params: {
          optional: ['timeRange']
        }
      }
    ],
    capabilities: [
      'multi-provider-routing',
      'intelligent-fallback',
      'streaming-support',
      'multi-speaker-tts',
      'rag-search',
      'openai-compatible',
      'cost-tracking',
      'request-tracing'
    ],
    supported_providers: ['openai', 'google', 'anthropic', 'ollama', 'perplexity'],
    timestamp: new Date().toISOString()
  });
});

/**
 * Helper function to determine provider from model name
 */
function determineProviderFromModel(model) {
  if (!model) return null;
  
  const modelLower = model.toLowerCase();
  
  // OpenAI models
  if (modelLower.startsWith('gpt-') || 
      modelLower.startsWith('o1-') || 
      modelLower.includes('davinci') ||
      modelLower.includes('turbo')) {
    return 'openai';
  }
  
  // Google Gemini models
  if (modelLower.startsWith('gemini-') || 
      modelLower.includes('palm')) {
    return 'google';
  }
  
  // Anthropic Claude models
  if (modelLower.startsWith('claude-')) {
    return 'anthropic';
  }
  
  // Ollama local models
  if (modelLower.includes('llama') || 
      modelLower.includes('mistral') ||
      modelLower.includes('mixtral') ||
      modelLower.includes('neural-chat') ||
      modelLower.includes('codellama')) {
    return 'ollama';
  }
  
  // Perplexity models
  if (modelLower.includes('sonar') || 
      modelLower.includes('pplx')) {
    return 'perplexity';
  }
  
  return null;
}

