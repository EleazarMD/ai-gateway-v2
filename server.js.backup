  console.log(`[EXTERNAL-8777] Content-Type: ${req.headers['content-type']}`);
  console.log(`[EXTERNAL-8777] API Key: ${req.headers['x-api-key'] ? 'present' : 'missing'}`);
  console.log(`[EXTERNAL-8777] Service-ID: ${req.headers['x-service-id'] || 'not provided'}`);
