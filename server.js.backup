#!/usr/bin/env node

/**
 * AI Gateway v2.0 - Dual Port Architecture
 * Streamlined proxy server for AI model orchestration
 * 
 * Architecture: Single-process, dual Express apps
 * Port 7777: Internal service mesh API (health, admin, service registration)
 * Port 8777: External AI inference API (chat completions, models, Perplexity)
 */

require('dotenv').config();
const express = require('express');
const cors = require('cors');
const { createProxyMiddleware } = require('http-proxy-middleware');
const axios = require('axios');
const http = require('http');
const WebSocket = require('ws');
const ServiceMeshIntegration = require('./src/service-mesh-integration');
const DashboardConfigService = require('./src/services/dashboard-config-service');
const AHISIntegrationService = require('./src/services/ahis-integration-service');
const ProviderManager = require('./src/services/provider-manager');
const APIKeyManager = require('./src/services/api-key-manager');
const APIKeyRoutes = require('./src/services/api-key-routes');
const AIInferencingClient = require('./src/clients/ai-inferencing-client');

// Monitoring and observability services
const RequestTracingService = require('./src/services/request-tracing-service');
const CostTrackingService = require('./src/services/cost-tracking-service');
const AlertService = require('./src/services/alert-service');
const TraceStorage = require('./src/storage/trace-storage');
const CostStorage = require('./src/storage/cost-storage');
const AlertStorage = require('./src/storage/alert-storage');

// Port configuration per PORT_REGISTRY
const INTERNAL_PORT = process.env.INTERNAL_PORT || 7777;  // Service mesh
const EXTERNAL_PORT = process.env.EXTERNAL_PORT || 8777;  // AI inference
const API_KEY = process.env.API_KEY || 'ai-gateway-api-key-2024';
const ADMIN_API_KEY = process.env.ADMIN_API_KEY || 'ai-gateway-admin-key-2024';
const OLLAMA_HOST = process.env.OLLAMA_BASE_URL || process.env.OLLAMA_HOST || 'http://localhost:11434';
// API Keys - will be fetched from Dashboard or fall back to env vars
let PERPLEXITY_API_KEY = process.env.PERPLEXITY_API_KEY;
let OPENAI_API_KEY = process.env.OPENAI_API_KEY;
let ANTHROPIC_API_KEY = process.env.ANTHROPIC_API_KEY;
let GOOGLE_API_KEY = process.env.GOOGLE_API_KEY;

// Fetch API keys from centralized Dashboard
async function fetchAPIKeysFromDashboard() {
  const DASHBOARD_URL = process.env.DASHBOARD_URL || 'http://localhost:8404';
  const GATEWAY_API_KEY = process.env.API_KEY || 'ai-gateway-api-key-2024';
  
  try {
    console.log('🔐 Fetching API keys from Dashboard...');
    const response = await axios.get(`${DASHBOARD_URL}/api/ai-gateway/get-provider-keys`, {
      headers: {
        'X-API-Key': GATEWAY_API_KEY
      },
      timeout: 5000
    });
    
    if (response.data && response.data.providers) {
      const keys = response.data.providers;
      
      // Update API keys from centralized source
      if (keys.google) {
        GOOGLE_API_KEY = keys.google;
        console.log('✅ Loaded Google API key from Dashboard');
      }
      if (keys.openai) {
        OPENAI_API_KEY = keys.openai;
        console.log('✅ Loaded OpenAI API key from Dashboard');
      }
      if (keys.anthropic) {
        ANTHROPIC_API_KEY = keys.anthropic;
        console.log('✅ Loaded Anthropic API key from Dashboard');
      }
      if (keys.perplexity) {
        PERPLEXITY_API_KEY = keys.perplexity;
        console.log('✅ Loaded Perplexity API key from Dashboard');
      }
      
      console.log(`✅ Loaded ${response.data.count} provider API keys from Dashboard`);
      return true;
    }
  } catch (error) {
    console.warn('⚠️  Could not fetch API keys from Dashboard, using environment variables');
    console.warn('   Error:', error.message);
    return false;
  }
}

// Initialize Provider Manager
const providerManager = new ProviderManager();

// Initialize AI Inferencing Client for multi-tenant key management
const AI_INFERENCING_URL = process.env.AI_INFERENCING_URL || 'http://localhost:9000';
const ENABLE_AI_INFERENCING = process.env.ENABLE_AI_INFERENCING === 'true';
const inferencingClient = new AIInferencingClient({
  baseUrl: AI_INFERENCING_URL,
  cacheTTL: 60000 // 1 minute cache
});

if (ENABLE_AI_INFERENCING) {
  console.log(`[AI Inferencing] Multi-tenant key management enabled: ${AI_INFERENCING_URL}`);
} else {
  console.log('[AI Inferencing] Multi-tenant disabled, using .env API keys');
}

// Initialize monitoring storage and services
const dbConfig = {
  host: process.env.POSTGRES_HOST || 'localhost',
  port: parseInt(process.env.POSTGRES_PORT || '5432'),
  database: process.env.POSTGRES_DB || 'ai_gateway_db',
  user: process.env.POSTGRES_USER || 'postgres',
  password: process.env.POSTGRES_PASSWORD,
};

// Storage layers (will initialize on first use)
const traceStorage = new TraceStorage(dbConfig);
const costStorage = new CostStorage(dbConfig);
const alertStorage = new AlertStorage(dbConfig);

// Monitoring services
const tracingService = new RequestTracingService(traceStorage);
const costService = new CostTrackingService(costStorage);
const alertService = new AlertService(alertStorage);

console.log('[Server] Monitoring services initialized (tracing, cost tracking, alerts)');

// Initialize API Key Manager and routes
let apiKeyManager;
let apiKeyRoutes;

// Create separate Express apps for each port
const internalApp = express();  // Port 7777 - Service mesh
const externalApp = express();  // Port 8777 - AI inference

// Shared middleware setup
const setupMiddleware = (app, portName) => {
  app.use(cors({
    origin: process.env.CORS_ORIGIN || '*',
    credentials: true,
    // Allow all headers to support A2A protocol and custom headers
    allowedHeaders: '*',
    exposedHeaders: ['X-RateLimit-Limit', 'X-RateLimit-Remaining', 'X-RateLimit-Reset']
  }));
  
  // Increase body size limit for large file uploads (PDFs, documents)
  // Default: 100mb for document analysis, configurable via env var
  const bodySizeLimit = process.env.BODY_SIZE_LIMIT || '100mb';
  app.use(express.json({ limit: bodySizeLimit }));
  app.use(express.urlencoded({ limit: bodySizeLimit, extended: true }));
  
  console.log(`[${portName}] Body size limit: ${bodySizeLimit}`);
  
  // Request logging with port identification
  app.use((req, res, next) => {
    console.log(`[${portName}] ${new Date().toISOString()} ${req.method} ${req.path}`);
    next();
  });
};

// Setup middleware for both apps
setupMiddleware(internalApp, 'INTERNAL-7777');
setupMiddleware(externalApp, 'EXTERNAL-8777');

// Authentication middleware for external API (client access)
// Authentication middleware for external API (client access)
// v2.4.0: Added support for Authorization: Bearer tokens (industry standard)
const authenticateExternal = (req, res, next) => {
  // Accept both X-API-Key (custom) and Authorization: Bearer (standard)
  const apiKey = req.headers['x-api-key'] || 
                 (req.headers['authorization']?.startsWith('Bearer ') 
                   ? req.headers['authorization'].slice(7) 
                   : null);
  
  if (!apiKey || apiKey !== API_KEY) {
    return res.status(401).json({ 
      error: 'Unauthorized',
      message: 'Valid X-API-Key or Authorization: Bearer header required'
    });
  }
  next();
};


// Authentication middleware for internal API (service mesh)
const authenticateInternal = (req, res, next) => {
  const apiKey = req.headers['x-api-key'];
  const adminKey = req.headers['x-admin-key'];
  
  if (adminKey && adminKey === ADMIN_API_KEY) {
    req.isAdmin = true;
    return next();
  }
  
  if (!apiKey || apiKey !== API_KEY) {
    return res.status(401).json({ 
      error: 'Unauthorized',
      message: 'Valid X-API-Key or X-Admin-Key header required'
    });
  }
  
  next();
};

