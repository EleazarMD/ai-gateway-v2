});

// ================== OpenAI-compatible endpoint (/api without version) ==================
// Debug middleware
externalApp.use('/api/chat/completions', require('express').json(), (req, res, next) => {
  console.log(`[EXTERNAL-8777] (compat) Chat completion request: ${req.method} ${req.url}`);
  next();
});

// Reuse early normalizer
externalApp.use('/api/chat/completions', (req, res, next) => {
  try {
    const original = req.body?.model;
    if (typeof original === 'string') {
      const ml = original.toLowerCase();
      let normalized = original;
      if (ml === 'gpt-4o' || ml.startsWith('gpt-4o-')) {
        normalized = 'claude-4-sonnet';
      } else if (ml === 'gpt-4o-mini' || ml.startsWith('gpt-4o-mini-')) {
        normalized = 'claude-3-5-haiku';
      } else if (ml === 'claude-sonnet-4-0') {
        normalized = 'claude-4-sonnet';
      }
      if (normalized !== original) {
        console.log(`[Model Normalizer][compat] ${original} → ${normalized}`);
        req.body.model = normalized;
      }
    }
  } catch (e) {
    console.warn('[Model Normalizer][compat] Skipped normalization:', e.message);
  }
  return next();
});

externalApp.use('/api/chat/completions', authenticateExternal);

externalApp.post('/api/chat/completions', authenticateExternal, async (req, res) => {
  try {
    console.log(`[Routing Precheck][compat] final model before routing: ${req.body?.model}`);
    const response = await providerManager.routeRequest(req.body, {
      strategy: req.headers['x-routing-strategy'] || 'hybrid'
    });
    return res.json(response);
  } catch (error) {
    console.error('[AI Gateway][compat] Chat completion failed:', error?.message || error);
    return res.status(500).json({
      error: {
        message: error?.message || 'Routing failed',
        type: 'routing_error'
      },
      _gateway: { version: '2.4.0', timestamp: new Date().toISOString(), error: true }
    });
  }
});

// Provider configuration endpoint for dashboard
internalApp.get('/api/v1/providers/config', authenticateInternal, async (req, res) => {
  try {
    const providers = providerManager.getActiveProviders();
    const providerConfigs = [];
    
    for (const providerId of providers) {
      const provider = providerManager.getProvider(providerId);
      if (provider) {
        const models = await provider.getAvailableModels();
        providerConfigs.push({
          id: providerId,
          name: provider.name,
          type: provider.type,
          status: provider.status,
          models: Array.isArray(models) ? models : [],
          capabilities: provider.capabilities,
          features: provider.features
        });
      }
    }
    
    res.json({
      success: true,
      data: { providers: providerConfigs },
      timestamp: new Date().toISOString()
    });
  } catch (error) {
    console.error('[INTERNAL-7777] Provider config error:', error);
    res.status(500).json({
      success: false,
      error: 'Provider configuration retrieval failed',
      message: error.message
    });
  }
});

// Provider configuration management endpoint (POST)
externalApp.post('/api/v1/config/providers', authenticateExternal, async (req, res) => {
  try {
    const { providers } = req.body;
    
    if (!Array.isArray(providers)) {
      return res.status(400).json({
        success: false,
        error: 'Invalid request format',
        message: 'Expected providers array in request body'
      });
    }
    
    console.log(`[EXTERNAL-8777] Applying provider configuration: ${providers.length} providers`);
    
    // Apply configuration to provider manager
    await providerManager.applyConfiguration({ providers });
    
    // Get updated status
    const connectivityStatus = await providerManager.getProviderConnectivityStatus();
    const activeProviders = providerManager.getActiveProviders();
    
    res.json({
      success: true,
      message: 'Provider configuration applied successfully',
      data: {
        totalProviders: providers.length,
        activeProviders: activeProviders.length,
        connectivityStatus
      },
      timestamp: new Date().toISOString()
    });
    
  } catch (error) {
    console.error('[EXTERNAL-8777] Provider configuration error:', error);
    res.status(500).json({
      success: false,
      error: 'Provider configuration failed',
      message: error.message,
      timestamp: new Date().toISOString()
    });
  }
});

