// Provider configuration management endpoint
internalApp.put('/admin/providers/:providerId', authenticateInternal, async (req, res) => {
  if (!req.isAdmin) {
    return res.status(403).json({ error: 'Admin access required' });
  }
  
  try {
    const { providerId } = req.params;
    const { enabled, ...updates } = req.body;
    
    console.log(`[AI Gateway] Admin request to ${enabled ? 'enable' : 'disable'} provider: ${providerId}`);
    
    if (!providerManager) {
      return res.status(500).json({ error: 'Provider manager not initialized' });
    }
    
    // Get current provider instance
    const provider = providerManager.getProvider(providerId);
    if (!provider) {
      return res.status(404).json({ error: `Provider ${providerId} not found` });
    }
    
    if (enabled === false) {
      // Disable provider by unloading it
      await providerManager.unloadProvider(providerId);
      console.log(`[AI Gateway] Provider ${providerId} disabled (unloaded)`);
    } else if (enabled === true) {
      // Re-enable provider (would need provider config - for now just return current status)
      console.log(`[AI Gateway] Provider ${providerId} enable requested - already active`);
    }
    
    // Return updated provider status
    const providerStatus = await providerManager.getProviderConnectivityStatus();
    const updatedProvider = providerStatus[providerId] || { 
      connected: enabled !== false, 
      status: enabled === false ? 'disabled' : 'active',
      lastUpdated: new Date().toISOString()
    };
    
    res.json({
      success: true,
      provider: providerId,
      status: updatedProvider,
      action: enabled === false ? 'disabled' : 'enabled'
    });
    
  } catch (error) {
    console.error(`[AI Gateway] Provider configuration error:`, error.message);
    res.status(500).json({ 
      error: 'Provider configuration failed', 
      message: error.message 
    });
  }
});

