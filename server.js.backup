// Text-to-Speech endpoint - Google AI Studio Generative Language API (Gemini voices)
// v2.3.0: Supports both single-speaker and multi-speaker TTS via parameter-based routing
externalApp.post('/api/v1/tts', authenticateExternal, async (req, res) => {
  const { 
    // Single-speaker parameters
    text, 
    voice, 
    speed = 1.0, 
    pitch = 0, 
    model,
    // Multi-speaker parameters (v2.3.0)
    mode,
    script,
    speakerVoices,
    // Accept additional parameters for future extensibility
    volumeGainDb,
    sampleRateHertz,
    ...additionalParams  // Capture any future parameters
  } = req.body;
  
  // Detect multi-speaker vs single-speaker mode
  const isMultiSpeaker = mode === 'multi-speaker' && script && speakerVoices;
  
  if (isMultiSpeaker) {
    // === MULTI-SPEAKER TTS (v2.3.0) ===
    console.log(`[EXTERNAL-8777] 🎭 Multi-speaker TTS request: ${speakerVoices.length} speakers, model=${model}`);
    
    // Validate multi-speaker parameters
    if (!script || !speakerVoices || speakerVoices.length === 0) {
      return res.status(400).json({
        error: 'Bad Request',
        message: 'Multi-speaker mode requires script and speakerVoices parameters',
        required: ['script', 'speakerVoices'],
        received: { script: !!script, speakerVoices: !!speakerVoices }
      });
    }
    
    if (!model) {
      return res.status(400).json({
        error: 'Bad Request',
        message: 'Model parameter is required (e.g., google-gemini-2.5-pro-preview-tts)'
      });
    }
    
    // Route to AI Inferencing multi-speaker endpoint
    const inferenceUrl = process.env.AI_INFERENCE_URL || 'http://localhost:9000';
    const inferenceKey = process.env.AI_INFERENCE_SERVICE_KEY || 'ai-inferencing-service-key-2024';
    
    try {
      console.log(`[EXTERNAL-8777] Routing to AI Inferencing: ${inferenceUrl}/api/tts/multi-speaker`);
      
      const response = await axios.post(`${inferenceUrl}/api/tts/multi-speaker`, {
        script,
        speakerVoices,
        model
      }, {
        headers: {
          'Content-Type': 'application/json',
          'X-Service-Key': inferenceKey
        },
        responseType: 'arraybuffer',
        timeout: 600000  // 10 minutes for large podcast generation
      });
      
      const audioBuffer = Buffer.from(response.data);
      
      res.set({
        'Content-Type': 'audio/wav',
        'Content-Length': audioBuffer.length,
        'X-TTS-Mode': 'multi-speaker',
        'X-Speaker-Count': speakerVoices.length.toString(),
        'Cache-Control': 'public, max-age=31536000'
      });
      
      console.log(`[EXTERNAL-8777] ✅ Multi-speaker TTS success: ${audioBuffer.length} bytes, ${speakerVoices.length} speakers`);
      res.send(audioBuffer);
      
    } catch (error) {
      console.error('[EXTERNAL-8777] Multi-speaker TTS error:', error.response?.data || error.message);
      res.status(error.response?.status || 500).json({
        error: 'Multi-speaker TTS Error',
        message: error.response?.data?.error || error.message,
        mode: 'multi-speaker'
      });
    }
    
  } else {
    // === SINGLE-SPEAKER TTS (Original) ===
    
    if (!text) {
      return res.status(400).json({
        error: 'Bad Request',
        message: 'Text parameter is required for single-speaker TTS'
      });
    }

    if (!model) {
      return res.status(400).json({
        error: 'Bad Request',
        message: 'Model parameter is required (e.g., gemini-2.5-pro-preview-tts)'
      });
    }

    if (!voice) {
      return res.status(400).json({
        error: 'Bad Request',
        message: 'Voice parameter is required'
      });
    }

    if (!GOOGLE_API_KEY) {
      return res.status(500).json({
        error: 'Configuration Error',
        message: 'GOOGLE_API_KEY environment variable is required for Gemini TTS'
      });
    }

    try {
      console.log(`[EXTERNAL-8777] 🎤 Single-speaker TTS request: model=${model}, voice=${voice}, text="${text.substring(0, 50)}..."`);
      if (Object.keys(additionalParams).length > 0) {
        console.log(`[EXTERNAL-8777] Additional TTS params:`, additionalParams);
      }
      
      // Build speech config with all supported parameters
      const speechConfig = {
        voice_config: {
          prebuilt_voice_config: {
            voice_name: voice
          }
        }
      };
      
      // Add optional Gemini TTS parameters if provided
      if (volumeGainDb !== undefined) {
        speechConfig.volume_gain_db = volumeGainDb;
      }
      if (sampleRateHertz !== undefined) {
        speechConfig.sample_rate_hertz = sampleRateHertz;
      }
      
      // Call Google Generative Language API for Gemini TTS
      // Gateway passes through all parameters - fully extensible
      const response = await axios.post(
        `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${GOOGLE_API_KEY}`,
        {
          contents: [{
            parts: [{
              text: text
            }]
          }],
          generationConfig: {
            response_modalities: ['AUDIO'],
            speech_config: speechConfig
          }
        },
        {
          headers: {
            'Content-Type': 'application/json'
          }
        }
      );

      if (!response.data || !response.data.candidates || !response.data.candidates[0]) {
        console.error('[EXTERNAL-8777] Gemini response structure:', JSON.stringify(response.data, null, 2));
        throw new Error('No audio content in response from Gemini API');
      }

      // Extract audio data from inline_data
      const candidate = response.data.candidates[0];
      console.log(`[EXTERNAL-8777] Candidate structure:`, JSON.stringify({
        finishReason: candidate.finishReason,
        hasContent: !!candidate.content,
        hasParts: !!candidate.content?.parts,
        partsLength: candidate.content?.parts?.length,
        partTypes: candidate.content?.parts?.map(p => Object.keys(p))
      }));
      
      const audioPart = candidate.content?.parts?.find(part => part.inline_data || part.inlineData);
      
      if (!audioPart) {
        console.error('[EXTERNAL-8777] No audio part found. Parts:', JSON.stringify(candidate.content?.parts, null, 2));
        throw new Error('No audio data found in Gemini response');
      }
      
      // Support both inline_data and inlineData (snake_case and camelCase)
      const inlineData = audioPart.inline_data || audioPart.inlineData;
      if (!inlineData) {
        console.error('[EXTERNAL-8777] Audio part has no inline data:', JSON.stringify(audioPart, null, 2));
        throw new Error('No inline data in audio part');
      }

      // Convert base64 to buffer (support both naming conventions)
      const audioBuffer = Buffer.from(inlineData.data, 'base64');
      const mimeType = inlineData.mime_type || inlineData.mimeType || 'audio/wav';

      // Send audio
      res.set({
        'Content-Type': mimeType,
        'Content-Length': audioBuffer.length,
        'X-TTS-Mode': 'single-speaker',
        'Cache-Control': 'public, max-age=31536000'
      });
      
      console.log(`[EXTERNAL-8777] ✅ Single-speaker TTS success: ${audioBuffer.length} bytes (${mimeType}) with voice=${voice}, model=${model}`);
      res.send(audioBuffer);

    } catch (error) {
      console.error('[EXTERNAL-8777] Gemini TTS error:', error.response?.data || error.message);
      res.status(error.response?.status || 500).json({
        error: 'Gemini TTS Error',
        message: error.response?.data?.error?.message || error.message,
        details: error.response?.data || null
      });
    }
  }
});

// Enhanced Perplexity search endpoint with dynamic provider selection
externalApp.post('/api/v1/perplexity/search', authenticateExternal, async (req, res) => {
  const { query, model = 'sonar', stream = false } = req.body;
  
  if (!query) {
    return res.status(400).json({
      error: 'Bad Request',
      message: 'Query parameter is required'
    });
  }

  // Use dynamic provider selection if available
  if (dashboardConfig && dashboardConfig.isHealthy) {
    try {
      return await handleDynamicPerplexitySearch(req, res, dashboardConfig);
    } catch (error) {
      console.warn('[EXTERNAL-8777] Dynamic provider selection failed, falling back to static:', error.message);
    }
  }

  // Fallback to static configuration
  if (!PERPLEXITY_API_KEY) {
    return res.status(500).json({
      error: 'Configuration Error',
      message: 'PERPLEXITY_API_KEY environment variable is required and no dynamic providers available'
    });
  }

  try {
    const perplexityRequest = {
      model,
      messages: [
        {
          role: 'system',
          content: 'You are a helpful assistant that provides accurate, up-to-date information from web sources. Always cite your sources and provide comprehensive answers.'
        },
        {
          role: 'user',
          content: query
        }
      ],
      max_tokens: req.body.maxTokens || 4000,
      temperature: req.body.temperature || 0.2,
      return_citations: true,
      return_related_questions: true,
      search_recency_filter: 'month',
      stream
    };

    if (stream) {
      // Set up SSE headers for streaming
      res.writeHead(200, {
        'Content-Type': 'text/event-stream',
        'Cache-Control': 'no-cache',
        'Connection': 'keep-alive',
        'Access-Control-Allow-Origin': '*',
        'Access-Control-Allow-Headers': 'Cache-Control'
      });

      const perplexityResponse = await axios.post(
        'https://api.perplexity.ai/chat/completions',
        perplexityRequest,
        {
          headers: {
            'Authorization': `Bearer ${PERPLEXITY_API_KEY}`,
            'Content-Type': 'application/json'
          },
          responseType: 'stream'
        }
      );

      perplexityResponse.data.on('data', (chunk) => {
        const lines = chunk.toString().split('\n');
        for (const line of lines) {
          if (line.startsWith('data: ')) {
            res.write(`${line}\n\n`);
          }
        }
      });

      perplexityResponse.data.on('end', () => {
        res.write('data: [DONE]\n\n');
        res.end();
      });

      perplexityResponse.data.on('error', (error) => {
        console.error('[EXTERNAL-8777] Perplexity streaming error:', error);
        res.write(`data: {"error": "Stream error: ${error.message}"}\n\n`);
        res.end();
      });

    } else {
      // Non-streaming response
      const perplexityResponse = await axios.post(
        'https://api.perplexity.ai/chat/completions',
        perplexityRequest,
        {
          headers: {
            'Authorization': `Bearer ${PERPLEXITY_API_KEY}`,
            'Content-Type': 'application/json'
          },
          timeout: 120000
        }
      );

      res.json(perplexityResponse.data);
    }

  } catch (error) {
    console.error('[EXTERNAL-8777] Perplexity search error:', error);
    
    if (stream && !res.headersSent) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
    }
    
    const errorResponse = {
      error: 'Perplexity API Error',
      message: error.response?.data?.error?.message || error.message,
      status: error.response?.status || 500
    };

    if (stream) {
      res.write(`data: ${JSON.stringify(errorResponse)}\n\n`);
      res.end();
    } else {
      res.status(errorResponse.status).json(errorResponse);
    }
  }
});

