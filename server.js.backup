// Provider selection endpoint for testing
externalApp.post('/api/providers/select', authenticateExternal, (req, res) => {
  try {
    const { model, capability, provider } = req.body;
    
    if (dashboardConfig) {
      const config = dashboardConfig.getCurrentConfiguration();
      const providers = config?.providers || [];
      
      // Simple provider selection logic for testing
      let selectedProvider = providers.find(p => 
        p.enabled && 
        (model ? p.models?.includes(model) : true) &&
        (capability ? p.capabilities?.includes(capability) : true) &&
        (provider ? p.id === provider : true)
      );
      
      if (!selectedProvider && providers.length > 0) {
        selectedProvider = providers.find(p => p.enabled);
      }
      
      if (selectedProvider) {
        res.json({
          success: true,
          provider: selectedProvider,
          timestamp: new Date().toISOString()
        });
      } else {
        res.status(404).json({
          success: false,
          error: 'No suitable provider found',
          criteria: { model, capability, provider },
          timestamp: new Date().toISOString()
        });
      }
    } else {
      res.status(503).json({
        success: false,
        error: 'Dynamic provider selection not available',
        timestamp: new Date().toISOString()
      });
    }
  } catch (error) {
    res.status(500).json({
      success: false,
      error: error.message,
      timestamp: new Date().toISOString()
    });
  }
});

